# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Visual Studio Marketplace Personal Access Token (PAT)
# Used for publishing the extension to the Visual Studio Marketplace
# Required scopes: Marketplace (Manage)
# Generate at: https://dev.azure.com/[organization]/_usersSettings/tokens
marketplace="YOUR_MARKETPLACE_PAT_TOKEN_HERE"
