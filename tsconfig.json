{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2023",
		"outDir": "out",
		"lib": [
			"ES2023"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"types": ["node", "vscode", "mocha", "sinon"]
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"out"
	]
}